SESSION_SECRET=change-me-to-a-long-random-string
DASHBOARD_USER=boss
DASHBOARD_PASSWORD=change-me
FINNHUB_API_KEY=
TWELVEDATA_API_KEY=
# Set to a Neon Postgres connection string in production.
# Leave UNSET in dev/test to use in-process pglite (WASM Postgres, no install).
DATABASE_URL=
# Resend API key for outbound email (watchlist alerts, invoices, etc). Leave UNSET to run sendEmail in simulated (no-op) mode.
RESEND_API_KEY=
# Verified "from" address for outbound email. Defaults to alerts@idesign.local when unset.
EMAIL_FROM=
